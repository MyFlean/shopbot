{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManager",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue",
        "secretsmanager:GetResourcePolicy"
      ],
      "Resource": [
        "arn:aws:secretsmanager:ap-south-1:637607366584:secret:shopping-bot/es-url*",
        "arn:aws:secretsmanager:ap-south-1:637607366584:secret:flean-services/shopbot*"
      ]
    },
    {
      "Sid": "Route53",
      "Effect": "Allow",
      "Action": "route53:*",
      "Resource": "*"
    },
    {
      "Sid": "Lambda",
      "Effect": "Allow",
      "Action": "lambda:*",
      "Resource": "arn:aws:lambda:ap-south-1:637607366584:function:shopbot-service"
    },
    {
      "Sid": "IAM",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:TagRole",
        "iam:UntagRole"
      ],
      "Resource": "arn:aws:iam::637607366584:role/shopbot-service-lambda-role"
    },
    {
      "Sid": "APIGateway",
      "Effect": "Allow",
      "Action": "apigateway:*",
      "Resource": "arn:aws:apigateway:ap-south-1::/*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": "logs:*",
      "Resource": [
        "arn:aws:logs:ap-south-1:637607366584:log-group:/aws/lambda/shopbot-service*",
        "arn:aws:logs:ap-south-1:637607366584:log-group:/aws/apigateway/shopbot-service*",
        "arn:aws:logs:ap-south-1:637607366584:log-group:*"
      ]
    }
  ]
}
